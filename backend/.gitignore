# ============================================
# Backend-specific .gitignore
# ============================================

# ============================================
# Environment Variables (CRITICAL - NEVER COMMIT!)
# ============================================
.env
.env.local
.env.development
.env.production
.env.test
*.env
!.env.example

# ============================================
# Dependencies
# ============================================
node_modules/
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids
*.pid
*.seed
*.pid.lock

# ============================================
# Uploads & User Content
# ============================================
uploads/
public/uploads/
static/uploads/
media/

# ============================================
# Temporary files
# ============================================
tmp/
temp/
*.tmp
*.temp

# ============================================
# Database files (if using local DB)
# ============================================
*.sqlite
*.sqlite3
*.db
data/

# ============================================
# OS generated files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# IDE & Editor files
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ============================================
# SSL/TLS Certificates
# ============================================
*.pem
*.key
*.cert
*.crt
ssl/
certs/

# ============================================
# Build outputs
# ============================================
dist/
build/
*.tsbuildinfo

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
*.coverage

# ============================================
# Package managers
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Session & Cache
# ============================================
sessions/
.cache/

# ============================================
# Email templates compiled (if any)
# ============================================
*.compiled.html
