# Backend Environment Variables Example
# Copy this file to .env and fill in your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Use a secure random string (at least 32 characters)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRE=7d

# ===========================================
# URL CONFIGURATION
# ===========================================
# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Backend URL (for payment callbacks)
BACKEND_URL=http://localhost:5000

# ===========================================
# IMAGE UPLOAD CONFIGURATION
# ===========================================
# ImgBB API key for image uploads
# Get your API key from: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ===========================================
# FILE UPLOAD LIMITS
# ===========================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png

# ===========================================
# STRIPE PAYMENT GATEWAY
# ===========================================
# Get your Stripe keys from: https://dashboard.stripe.com/apikeys
#
# FOR TESTING (Sandbox):
# - Use test keys that start with 'sk_test_' and 'pk_test_'
# - Use test card numbers like 4242424242424242
#
# FOR PRODUCTION (Live):
# - Use live keys that start with 'sk_live_' and 'pk_live_'
# - Real payments will be processed
#
# Secret Key (Backend only - never expose this!)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# Publishable Key (Can be used on frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Webhook Secret (For verifying webhook signatures)
# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE

# ===========================================
# SSLCOMMERZ PAYMENT GATEWAY
# ===========================================
# Get your SSLCommerz credentials from: https://developer.sslcommerz.com/
#
# FOR TESTING (Sandbox):
# 1. Register at https://developer.sslcommerz.com/registration/
# 2. Go to Developer Panel > API Credentials
# 3. Copy your Sandbox Store ID and Store Password
#
# FOR PRODUCTION (Live):
# 1. Apply for merchant account at https://www.sslcommerz.com/
# 2. After approval, get live credentials from merchant panel
# 3. Set NODE_ENV=production to use live mode
#
# Store ID (Provided by SSLCommerz)
SSLCOMMERZ_STORE_ID=your_store_id_here

# Store Password (Provided by SSLCommerz)
SSLCOMMERZ_STORE_PASSWORD=your_store_password_here

# ===========================================
# IMPORTANT NOTES
# ===========================================
# 
# 1. STRIPE SETUP:
#    - Create account: https://stripe.com
#    - Get API keys: https://dashboard.stripe.com/apikeys
#    - For Bangladesh, you may need a Stripe Atlas account
#    - Supports: Visa, Mastercard, AMEX internationally
#
# 2. SSLCOMMERZ SETUP:
#    - Register: https://developer.sslcommerz.com/registration/
#    - Get sandbox credentials from developer panel
#    - For production, apply at https://www.sslcommerz.com/
#    - Supports: bKash, Nagad, Rocket, Cards, Bank Transfer
#
# 3. WEBHOOK SETUP (Stripe):
#    - Local testing: Use Stripe CLI
#      $ stripe listen --forward-to localhost:5000/api/payments/stripe/webhook
#    - Production: Add webhook endpoint in Stripe Dashboard
#      URL: https://your-domain.com/api/payments/stripe/webhook
#
# 4. CALLBACK URLs (SSLCommerz):
#    - Success: BACKEND_URL/api/payments/sslcommerz/success
#    - Fail: BACKEND_URL/api/payments/sslcommerz/fail
#    - Cancel: BACKEND_URL/api/payments/sslcommerz/cancel
#    - IPN: BACKEND_URL/api/payments/sslcommerz/ipn
