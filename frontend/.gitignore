!.yarn/versions

# ============================================
# Environment Variables (CRITICAL - NEVER COMMIT!)
# ============================================
.env
.env*.local
.env.development
.env.production
.env.test
backend/.env
frontend/.env

# ============================================
# Next.js (Frontend)
# ============================================
/.next/
/out/
.next/
out/
build/
dist/

# ============================================
# Testing
# ============================================
.nyc_output
.jest-cache

# ============================================
# Build outputs
# ============================================
/build
*.tsbuildinfo
next-env.d.ts

# ============================================
# IDE & Editor files
# ============================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ============================================
# OS generated files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids
*.pid
*.seed
*.pid.lock

# ============================================
# Temporary files
# ============================================
tmp/
temp/
*.tmp
*.temp

# ============================================
# Package managers
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
