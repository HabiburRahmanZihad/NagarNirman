# ============================================
*.pem
*.key
*.cert
*.crt

# ============================================
# Vercel
# ============================================
.vercel
.vercel.json

# ============================================
# Backend specific
# ============================================
backend/uploads/
backend/public/uploads/
backend/logs/
backend/tmp/

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3
*.db

# ============================================
